ENVIRONMENT=production
APP_NAME=secure-distributed-file-vault
DEBUG=False

DATABASE_URL=postgresql+asyncpg://vault_user:vault_password@postgres:5432/vault_db
REDIS_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/1
REDIS_BACKEND_URL=redis://redis:6379/2

JWT_SECRET_KEY=replace-with-secure-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=["http://localhost:3000"]
RATE_LIMIT=100/minute
MAX_UPLOAD_SIZE=104857600
STORAGE_NODE_COUNT=5
