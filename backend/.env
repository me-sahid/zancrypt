ENVIRONMENT=production
APP_NAME=secure-distributed-file-vault
DEBUG=False

DATABASE_URL=postgresql+asyncpg://user:password@db:5432/vault
REDIS_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/1
REDIS_BACKEND_URL=redis://redis:6379/2

JWT_SECRET_KEY=yuuvault-enterprise-secure-key-2024
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=["*"]
RATE_LIMIT=100/minute
MAX_UPLOAD_SIZE=104857600
STORAGE_NODE_COUNT=5
